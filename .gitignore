# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# git worktrees
/.worktrees/

# pyodide runtime assets — copied from node_modules/pyodide by the
# postinstall script (scripts/copy-pyodide-assets.js), regenerated on every
# npm install so they don't need to be committed
/public/pyodide/

# typescript
*.tsbuildinfo
next-env.d.ts
